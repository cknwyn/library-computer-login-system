# ============================================================
# Library Kiosk Client — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# The PHP server base URL (no trailing slash)
# Local testing:
API_BASE_URL=http://localhost/library-system/api

# Production (nComputing server — use the server's LAN IP):
# API_BASE_URL=http://192.168.1.100/library-system/api

# This terminal's unique code — must match a row in the 'terminals' table
# For local testing, use LOCAL-TEST (it's in the seed data)
TERMINAL_CODE=LOCAL-TEST

# Set to 'true' to lock the window full-screen (production)
# Set to 'false' to allow normal windowed mode (local testing)
KIOSK_MODE=false

# Heartbeat interval in seconds (how often to ping the server)
HEARTBEAT_INTERVAL=30
