{
  "name": "library-kiosk-client",
  "version": "1.0.0",
  "description": "Library Computer Login System — Kiosk Client",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env KIOSK_MODE=false electron .",
    "build": "electron-builder --win --x64"
  },
  "keywords": [],
  "author": "Library IT",
  "license": "UNLICENSED",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "dotenv": "^16.4.1"
  },
  "build": {
    "appId": "com.library.kiosk",
    "productName": "Library Kiosk",
    "directories": { "output": "dist" },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
