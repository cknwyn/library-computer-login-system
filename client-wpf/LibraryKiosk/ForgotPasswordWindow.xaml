<Window x:Class="LibraryKiosk.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password" 
        SizeToContent="Height" Width="360" 
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    
    <Border Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid Margin="25,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Error -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock x:Name="TitleTxt" Text="Reset Password" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock x:Name="StepDesc" Text="Enter your ID to receive a code" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Content Area (Step Panels) -->
            <Grid Grid.Row="1">
                <!-- Step 1: Identity -->
                <StackPanel x:Name="IdentifyPanel" Visibility="Visible">
                    <TextBlock Text="STUDENT/STAFF ID" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <TextBox x:Name="UserIdInput" Style="{StaticResource KioskInput}" Tag="XX-XXXX-XXX"/>
                </StackPanel>

                <!-- Step 2: Verification -->
                <StackPanel x:Name="VerifyPanel" Visibility="Collapsed">
                    <TextBlock Text="6-DIGIT CODE" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <TextBox x:Name="CodeInput" Style="{StaticResource KioskInput}" Tag="000000" MaxLength="6"/>
                    <TextBlock Text="Check your email for the code." FontSize="12" Foreground="#64748B" Margin="0,12,0,0"/>
                </StackPanel>

                <!-- Step 3: New Password -->
                <StackPanel x:Name="ResetPanel" Visibility="Collapsed">
                    <TextBlock Text="NEW PASSWORD" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="NewPasswordInput" Style="{StaticResource KioskPasswordInput}" Margin="0,0,0,16"/>
                    
                    <TextBlock Text="CONFIRM PASSWORD" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="ConfirmPasswordInput" Style="{StaticResource KioskPasswordInput}"/>
                </StackPanel>
            </Grid>

            <!-- Global Error -->
            <TextBlock x:Name="ErrorMsg" Grid.Row="2" Margin="0,10,0,0" Foreground="#EF4444" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" Visibility="Collapsed"/>

            <!-- Footer -->
            <Grid Grid.Row="3" Margin="0,15,0,0">
                <Button x:Name="CancelBtn" Content="Cancel" Click="CancelBtn_Click" HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Foreground="#64748B"/>
                
                <Button x:Name="ActionBtn" Content="Send Code" Click="ActionBtn_Click" HorizontalAlignment="Right" Width="120" Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
