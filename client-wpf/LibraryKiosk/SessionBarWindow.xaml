<Window x:Class="LibraryKiosk.SessionBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Bar" 
        Height="100" Width="420"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    
    <Border Background="White" 
            CornerRadius="20" 
            Margin="10,5,10,20" 
            Padding="20,15"
            BorderThickness="1" 
            BorderBrush="#E2E8F0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" Opacity="0.1" ShadowDepth="5"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Timer Icon -->
            <Border Grid.Column="0" 
                    Width="36" Height="36" 
                    Background="#F0F4F8" 
                    CornerRadius="18"
                    Margin="0,0,12,0">
                <TextBlock Text="⏱" 
                           FontSize="20" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- User Info -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="TerminalText" 
                           Text="PC-04" 
                           FontSize="14" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryBlueBrush}"
                           LineHeight="16"/>
                <TextBlock x:Name="UserText" 
                           Text="Active User: J. Doe" 
                           FontSize="11" 
                           Foreground="{StaticResource TextLightBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="220"
                           Margin="0,1,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Minimize to Tray Button -->
                <Button Width="36" Height="36" 
                        Background="Transparent" 
                        BorderThickness="1" 
                        BorderBrush="#E2E8F0"
                        Margin="0,0,8,0"
                        Click="Minimize_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="brd" Background="{TemplateBinding Background}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    CornerRadius="8">
                                <TextBlock Text="—" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="brd" Property="Background" Value="#F7FAFC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Settings/Logout Icon -->
                <Button Width="36" Height="36" 
                        Background="Transparent" 
                        BorderThickness="1" 
                        BorderBrush="#E2E8F0"
                        Click="Settings_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="brd" Background="{TemplateBinding Background}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    CornerRadius="8">
                                <TextBlock Text="⚙" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="brd" Property="Background" Value="#F7FAFC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
