<Window x:Class="LibraryKiosk.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AUF Library Login" 
        WindowState="Maximized" 
        WindowStyle="None" 
        Topmost="True"
        Background="#F5F7FA"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="40" Direction="270" Opacity="0.1" ShadowDepth="10"/>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0"/>
                <GradientStop Color="#F1F5F9" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Centered Header Logo -->
            <Image Source="/assets/logo.png" 
                   Width="280" 
                   Margin="0,0,0,40"
                   HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Login Card -->
            <Border Background="White" 
                    Width="480" 
                    CornerRadius="16" 
                    Padding="60,60" 
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <!-- Student/Staff ID -->
                    <TextBlock Text="STUDENT/STAFF ID" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource TextLightBrush}" 
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="UserIdInput" 
                             Style="{StaticResource KioskInput}" 
                             Tag="XX-XXXX-XXX"
                             Margin="0,0,0,32"/>

                    <!-- Password -->
                    <TextBlock Text="PASSWORD" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource TextLightBrush}" 
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="PasswordInput" 
                                 Style="{StaticResource KioskPasswordInput}" 
                                 Margin="0,0,0,48"
                                 KeyDown="PasswordInput_KeyDown"/>

                    <!-- Footer Actions -->
                    <Grid>
                        <Button x:Name="ForgotPwBtn" 
                                Content="Forgot Password?" 
                                Background="Transparent" 
                                BorderThickness="0"
                                Foreground="{StaticResource TextLightBrush}" 
                                FontSize="13"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Cursor="Hand"
                                Click="ForgotPwBtn_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}" 
                                               TextDecorations="Underline"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button x:Name="LoginBtn" 
                                Content="Login" 
                                Style="{StaticResource PrimaryButton}" 
                                HorizontalAlignment="Right"
                                Width="140"
                                Click="LoginBtn_Click"/>
                    </Grid>

                    <!-- Error Message -->
                    <TextBlock x:Name="ErrorMsg" 
                               Foreground="{StaticResource ErrorRedBrush}" 
                               Margin="0,24,0,0" 
                               FontSize="13"
                               HorizontalAlignment="Center" 
                               Visibility="Collapsed"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid VerticalAlignment="Bottom" Margin="0,0,0,40">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel VerticalAlignment="Center" Margin="0,0,30,0">
                    <TextBlock Text="TERMINAL STATUS" FontSize="10" Foreground="{StaticResource TextLightBrush}" FontWeight="Bold"/>
                    <TextBlock x:Name="TerminalNameTxt" Text="Terminal Online" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                </StackPanel>

                <!-- Status Pill -->
                <Border Background="#E2E8F0" CornerRadius="20" Padding="15,8">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#4ADE80" Margin="0,0,10,0"/>
                        <TextBlock x:Name="StatusTxt" Text="CONNECTED TO SERVER" 
                                   FontSize="10" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource TextDarkBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
