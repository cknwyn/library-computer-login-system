<Window x:Class="LibraryKiosk.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AUF Library Login" 
        WindowState="Maximized" 
        WindowStyle="None" 
        Topmost="True"
        Background="#F5F7FA">
    
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="40" Direction="270" Opacity="0.1" ShadowDepth="10"/>
    </Window.Resources>

    <Grid>
        <!-- Background Image -->
        <Image Source="/assets/client_background.jpg" 
               Stretch="UniformToFill" 
               Opacity="0.4"
               RenderOptions.BitmapScalingMode="HighQuality"/>
        
        <!-- Subtle Dark Gradient Overlay for readability -->
        <Border Background="Black" Opacity="0.6"/>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Centered Header Logo -->
            <Image Source="/assets/logo.png" 
                   Width="280" 
                   Margin="0,0,0,40"
                   HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Login Card -->
            <Border Background="White" 
                    Width="480" 
                    CornerRadius="16" 
                    Padding="60,60" 
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <!-- Student/Staff ID -->
                    <TextBlock Text="STUDENT/STAFF ID" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource TextLightBrush}" 
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="UserIdInput" 
                             Style="{StaticResource KioskInput}" 
                             Tag="XX-XXXX-XXX"
                             Margin="0,0,0,32"/>

                    <!-- Password -->
                    <TextBlock Text="PASSWORD" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource TextLightBrush}" 
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="PasswordInput" 
                                 Style="{StaticResource KioskPasswordInput}" 
                                 Margin="0,0,0,48"
                                 KeyDown="PasswordInput_KeyDown"/>

                    <!-- Footer Actions -->
                    <Grid>
                        <TextBlock Text="Need assistance?" 
                                   VerticalAlignment="Center" 
                                   FontSize="13"
                                   Foreground="{StaticResource TextLightBrush}" 
                                   Cursor="Hand"/>
                        
                        <Button x:Name="LoginBtn" 
                                Content="Login" 
                                Style="{StaticResource PrimaryButton}" 
                                HorizontalAlignment="Right"
                                Width="140"
                                Click="LoginBtn_Click"/>
                    </Grid>

                    <!-- Error Message -->
                    <TextBlock x:Name="ErrorMsg" 
                               Foreground="{StaticResource ErrorRedBrush}" 
                               Margin="0,24,0,0" 
                               FontSize="13"
                               HorizontalAlignment="Center" 
                               Visibility="Collapsed"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Bottom Status Bar -->
        <Grid VerticalAlignment="Bottom" Margin="0,0,0,40">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel VerticalAlignment="Center" Margin="0,0,30,0">
                    <TextBlock Text="TERMINAL STATUS" FontSize="10" Foreground="White" Opacity="0.7"/>
                    <TextBlock x:Name="TerminalNameTxt" Text="Terminal Online" FontWeight="Bold" Foreground="White"/>
                </StackPanel>

                <!-- Status Pill -->
                <Border Background="#22FFFFFF" CornerRadius="20" Padding="15,8">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#4ADE80" Margin="0,0,10,0"/>
                        <TextBlock x:Name="StatusTxt" Text="CONNECTED TO SERVER" 
                                   FontSize="10" 
                                   FontWeight="Bold" 
                                   Foreground="White"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
