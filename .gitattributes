# ============================================================
# Git LFS — track large binary files
# ============================================================

# Built Electron installers / executables
# *.exe filter=lfs diff=lfs merge=lfs -text (Disabled: caused 1KB corruption issues for user)
*.dmg filter=lfs diff=lfs merge=lfs -text
*.AppImage filter=lfs diff=lfs merge=lfs -text
*.snap filter=lfs diff=lfs merge=lfs -text

# Archives / release packages
*.zip  filter=lfs diff=lfs merge=lfs -text
*.tar  filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
*.nsis filter=lfs diff=lfs merge=lfs -text

# Database dumps (if ever committed)
*.sql.gz filter=lfs diff=lfs merge=lfs -text

# Media assets
*.mp4  filter=lfs diff=lfs merge=lfs -text
*.mov  filter=lfs diff=lfs merge=lfs -text
*.png  filter=lfs diff=lfs merge=lfs -text
*.jpg  filter=lfs diff=lfs merge=lfs -text
*.gif  filter=lfs diff=lfs merge=lfs -text
*.ico  filter=lfs diff=lfs merge=lfs -text
